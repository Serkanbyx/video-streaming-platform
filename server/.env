PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/fragment

JWT_SECRET=dev-only-secret-change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

CLIENT_ORIGIN=http://localhost:5173

MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR_RAW=uploads/raw
UPLOAD_DIR_PROCESSED=uploads/processed

HLS_SEGMENT_DURATION=10
THUMBNAIL_TIMESTAMP=00:00:02
MAX_VIDEO_DURATION_SECONDS=600

DISK_QUOTA_MB=2800

SEED_ADMIN_EMAIL=admin@fragment.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=devadminpass123
