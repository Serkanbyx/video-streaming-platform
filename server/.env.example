# ─── Runtime ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ───────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/fragment
# Atlas:  mongodb+srv://<user>:<password>@<cluster>/fragment
MONGO_URI=mongodb://127.0.0.1:27017/fragment

# ─── Auth ───────────────────────────────────────────────────
# In production JWT_SECRET MUST be at least 32 characters.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── CORS ───────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173

# ─── Uploads & Storage ──────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR_RAW=uploads/raw
UPLOAD_DIR_PROCESSED=uploads/processed

# ─── FFmpeg / HLS ───────────────────────────────────────────
HLS_SEGMENT_DURATION=10
THUMBNAIL_TIMESTAMP=00:00:02
MAX_VIDEO_DURATION_SECONDS=600

# ─── Disk Quota (admin dashboard alerting) ──────────────────
DISK_QUOTA_MB=2800

# ─── Admin Seed (only used by `npm run seed:admin`) ─────────
# Run once after first deploy to bootstrap the initial admin.
# In production, SEED_ADMIN_PASSWORD MUST be at least 12 characters.
SEED_ADMIN_EMAIL=admin@fragment.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-strong-password
