{
  "name": "fragment",
  "version": "1.0.0",
  "private": true,
  "description": "FRAGMENT — brutalist video streaming platform (TypeScript monorepo).",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "lint": "npm run lint --workspace=fragment-client",
    "typecheck": "tsc -b",
    "type-check": "tsc -b",
    "type-check:server": "tsc -p server",
    "type-check:client": "tsc -p client"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
